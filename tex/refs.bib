	date-modified = {2022-11-13 07:26:28 -0500},
	eid = {111},
	eprint = {1910.04168},
	journal = {\apj},
	keywords = {Galaxy properties, Galaxy formation, Galaxy abundances, High-redshift galaxies, 615, 595, 574, 734, Astrophysics - Astrophysics of Galaxies},
	month = apr,
	number = {2},
	pages = {111},
	primaryclass = {astro-ph.GA},
	title = {{A New Census of the 0.2 < z < 3.0 Universe. I. The Stellar Mass Function}},
	volume = {893},
	year = 2020,
	bdsk-file-1 = {},
	bdsk-url-1 = {https://doi.org/10.3847/1538-4357/ab7e27},
