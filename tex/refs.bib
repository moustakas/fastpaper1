	journal = {\mnras},
	keywords = {galaxies: active, galaxies: nuclei, galaxies: star formation, Astrophysics - Astrophysics of Galaxies},
	month = dec,
	number = {4},
	pages = {5749-5764},
	primaryclass = {astro-ph.GA},
	title = {{Constraining photoionization models with a reprojected optical diagnostic diagram}},
	volume = {499},
	year = 2020,
