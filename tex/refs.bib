@article{soto25a,
	abstract = {Post-starburst galaxies are galaxies that are no longer producing stars and have entered or are entering quiescence. These galaxies can be identified with spectral features, for which the Dark Energy Spectroscopic Instrument (DESI) data provides an opportunity to do so at a higher redshift range compared to previous work with SDSS. Within the DESI field, we have selected 62,808 quiescent galaxies that meet our SNR cut and then measured the Lick Hδ<SUB>A</SUB> index to find 367 recently quiescent galaxies. We have observed a higher rate of post-starburst galaxies at 0.49 &lt; z &lt; 1.39 selected using [O II] than z &lt; 0.49 selected using Hα.},
