	date-modified = {2013-03-13 00:27:33 +0000},
	eprint = {arXiv:astro-ph/9807187},
	journal = {\araa},
	pages = {189-232},
	title = {{Star Formation in Galaxies Along the Hubble Sequence}},
	volume = 36,
	year = 1998,
