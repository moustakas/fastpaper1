	eprint = {1604.08592},
	journal = {ArXiv e-prints},
	keywords = {Astrophysics - Solar and Stellar Astrophysics},
	month = apr,
	primaryclass = {astro-ph.SR},
	title = {{MESA Isochrones and Stellar Tracks (MIST). I: Solar-Scaled Models}},
